{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode-federal-platform-pack/schemas/command-routing.schema.json",
  "title": "Command Routing",
  "description": "Routing matrix for commands to agents, skills, and output schemas",
  "type": "object",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "repo-assess",
        "solution-discovery",
        "platform-design",
        "federal-checklist",
        "gitops-audit",
        "quality-gate",
        "doc-sync",
        "verify",
        "checkpoint",
        "orchestrate"
      ]
    },
    "agent": {
      "type": "string",
      "enum": [
        "solution-architect",
        "product-manager-discovery",
        "repo-auditor",
        "federal-security-reviewer",
        "gitops-reviewer",
        "cloud-platform-reviewer",
        "documentation-writer"
      ]
    },
    "primary_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supporting_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_schema": {
      "type": "string"
    },
    "lifecycle_phase": {
      "type": "string",
      "enum": ["discovery", "assessment", "synthesis", "verification", "orchestration", "checkpointing", "documentation"]
    }
  }
}
