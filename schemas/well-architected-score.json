{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode-federal-platform-pack/schemas/well-architected-score.json",
  "title": "Well-Architected Score",
  "description": "Universal platform engineering scorecard. Cloud-agnostic. Derived from Well-Architected pillars.",
  "type": "object",
  "required": ["executive_summary", "categories", "verdict"],
  "properties": {
    "executive_summary": {
      "type": "string",
      "description": "1–3 sentence overview of posture, top risks, and verdict"
    },
    "categories": {
      "type": "object",
      "description": "Score 0–10 per category. 0=absent/critical failure, 10=excellent.",
      "required": ["security", "reliability", "performance", "cost", "operations"],
      "properties": {
        "security": {
          "$ref": "#/definitions/categoryScore",
          "description": "Access control, secrets, encryption, network exposure, supply chain"
        },
        "reliability": {
          "$ref": "#/definitions/categoryScore",
          "description": "Failure modes, recovery, health checks, redundancy"
        },
        "performance": {
          "$ref": "#/definitions/categoryScore",
          "description": "Scaling, bottlenecks, latency, resource limits"
        },
        "cost": {
          "$ref": "#/definitions/categoryScore",
          "description": "Right-sizing, waste, cost attribution, budget visibility"
        },
        "operations": {
          "$ref": "#/definitions/categoryScore",
          "description": "Observability, documentation, runbooks, change control"
        }
      }
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Average of category scores; or weighted by criticality"
    },
    "key_risks": {
      "type": "array",
      "items": { "$ref": "#/definitions/risk" },
      "description": "Ranked by severity"
    },
    "evidence_found": {
      "type": "array",
      "items": { "$ref": "#/definitions/evidence" },
      "description": "What was observed; file paths, configs"
    },
    "missing_evidence": {
      "type": "array",
      "items": { "$ref": "#/definitions/missingEvidence" },
      "description": "What could not be verified; recommend validation"
    },
    "recommended_actions": {
      "type": "array",
      "items": { "$ref": "#/definitions/action" },
      "description": "Prioritized; concrete; with effort and impact"
    },
    "verdict": {
      "type": "string",
      "enum": ["ready", "conditional", "not_ready"],
      "description": "ready: no critical failures. conditional: high-risk findings. not_ready: critical failures."
    }
  },
  "definitions": {
    "categoryScore": {
      "type": "object",
      "required": ["score", "explanation"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "0–10"
        },
        "explanation": {
          "type": "string",
          "description": "Brief rationale for the score"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths, configs, manifests supporting the score"
        },
        "missing_evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "What could not be verified in this category"
        }
      }
    },
    "risk": {
      "type": "object",
      "required": ["title", "severity"],
      "properties": {
        "title": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "evidence": { "type": "string" },
        "recommendation": { "type": "string" }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "description": { "type": "string" },
        "label": {
          "type": "string",
          "enum": ["observed", "inferred"]
        }
      }
    },
    "missingEvidence": {
      "type": "object",
      "properties": {
        "area": { "type": "string" },
        "recommendation": { "type": "string" }
      }
    },
    "action": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "effort": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "impact": { "type": "string" },
        "priority": { "type": "integer" }
      }
    }
  }
}
