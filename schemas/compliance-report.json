{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opencode-federal-platform-pack/schemas/compliance-report.json",
  "title": "Federal Compliance Report",
  "description": "Schema for federal compliance review output structure",
  "type": "object",
  "properties": {
    "executive_summary": {
      "type": "string",
      "description": "Overall compliance posture and critical gaps"
    },
    "control_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "control_id": { "type": "string", "description": "e.g. AC-2, SC-7" },
          "status": { "type": "string", "enum": ["Met", "Partial", "Gap"] },
          "evidence": { "type": "string" },
          "gap_description": { "type": "string" }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["High", "Medium", "Low"] },
          "control_id": { "type": "string" },
          "evidence": { "type": "string" },
          "remediation": { "type": "string" }
        }
      }
    },
    "remediation_roadmap": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "phase": { "type": "string" },
          "items": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
